FROM node:20-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --break-system-packages yt-dlp demucs

COPY package*.json ./
RUN npm install

COPY api-server.js ./

EXPOSE 3001

CMD ["node", "api-server.js"]