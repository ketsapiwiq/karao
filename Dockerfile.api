FROM oven/bun:1

WORKDIR /app

RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    ffmpeg \
    nodejs \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --break-system-packages yt-dlp demucs torchaudio

COPY package*.json ./
RUN bun install

COPY api-server.ts demucs_worker.py ./

EXPOSE 3001

CMD ["bun", "run", "api-server.ts"]